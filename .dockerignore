.git/
.gitignore

# Documentation
README.md
docs/

# Tests
src/test/

# Configuration locale
application-local.properties
application-dev.properties

# Docker
Dockerfile
docker-compose.yml
.dockerignore

# Déploiement
deployment/

# Node (si vous utilisez des outils frontend)
node_modules/
npm-debug.log*

# Build tools
.mvn/
mvnw
mvnw.cmd
